# ── Frontend (safe to expose — anon/publishable key) ──────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-or-publishable-key
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
VITE_STRIPE_MONTHLY_PRICE=price_xxx
VITE_STRIPE_YEARLY_PRICE=price_xxx

# Ads master switch — only show ad banners when "true" (set after AdSense approval)
VITE_ADS_ENABLED=false

# Dev mode — local testing bypasses (DEV panel, isPro/auth/ads overrides).
# MUST be false or omitted in production.
VITE_DEV_MODE=false

# ── Server only — used by /api functions (NEVER prefix with VITE_) ──
# Set these in Vercel → Project → Settings → Environment Variables.
# For local testing run `vercel dev` (plain `vite` does NOT serve /api).
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
