# ── Frontend (safe to expose — publishable keys) ──────────────────
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxxxx
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
VITE_STRIPE_MONTHLY_PRICE=price_xxx
VITE_STRIPE_YEARLY_PRICE=price_xxx

# Ads master switch — only show ad banners when "true" (after AdSense approval)
VITE_ADS_ENABLED=false

# Dev mode — local testing bypasses. MUST be false/omitted in production.
VITE_DEV_MODE=false

# ── Server only — used by /api functions (NEVER prefix with VITE_) ──
# Set these in Vercel → Project → Settings → Environment Variables.
CLERK_SECRET_KEY=sk_test_xxxxx
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
ANTHROPIC_API_KEY=sk-ant-xxx
# Vercel Blob — for Pro large-file uploads (Vercel → Storage → Blob)
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxx
